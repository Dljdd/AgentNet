# AgentNet Environment Configuration

# Private key for agent wallets (use a testnet key!)
PRIVATE_KEY=0x...

# 0G Chain Testnet
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_STORAGE_ENDPOINT=https://storage-testnet.0g.ai
ZG_COMPUTE_ENDPOINT=https://compute-testnet.0g.ai
ZG_DA_ENDPOINT=https://da-testnet.0g.ai
CHAIN_ID=16600

# Uniswap Trading API
UNISWAP_API_KEY=your-uniswap-api-key

# KeeperHub (workflow automation — guarantees on-chain execution)
# Get your org API key from https://app.keeperhub.com/settings/api-keys
# The key must belong to the same KeeperHub org that owns the workflow IDs below.
KEEPERHUB_API_KEY=your-keeperhub-api-key
KEEPERHUB_BASE_URL=https://app.keeperhub.com
# Pre-provisioned AgentNet workflow IDs (defaults are already set in code)
KEEPERHUB_REPUTATION_WORKFLOW_ID=lza9g0c0dviu5mu0we7j2
KEEPERHUB_PAYMENT_WORKFLOW_ID=qpkwci7tw0dr3dlnjv0d6

# Contract Addresses (filled after deployment)
REPUTATION_ORACLE_ADDRESS=
WORKER_REGISTRY_ADDRESS=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
