# AgentNet Environment Configuration

# Private key for agent wallets (use a testnet key!)
PRIVATE_KEY=0x...

# 0G Chain Testnet (Galileo)
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
CHAIN_ID=16602

# 0G Storage — indexer RPC for file/KV uploads
ZG_STORAGE_ENDPOINT=https://indexer-storage-testnet-turbo.0g.ai
# 0G KV node — for reading stored key-value data (default is set in code)
# ZG_KV_ENDPOINT=http://3.101.147.150:6789
# 0G Flow contract on Galileo testnet (default is set in code)
# ZG_FLOW_CONTRACT=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296

# 0G Compute — OpenAI-compatible inference router
# Endpoint: https://router-api.0g.ai/v1
ZG_COMPUTE_ENDPOINT=https://router-api-testnet.integratenetwork.work/v1
# API key from https://pc.0g.ai (deposit 0G tokens, then copy your key)
# This is SEPARATE from your ETH private key.
ZG_COMPUTE_API_KEY=your-0g-compute-api-key

# 0G DA
ZG_DA_ENDPOINT=https://da-testnet.0g.ai

# Uniswap Trading API
UNISWAP_API_KEY=your-uniswap-api-key

# KeeperHub (workflow automation — guarantees on-chain execution)
# Get your org API key from https://app.keeperhub.com/settings/api-keys
# The key must belong to the same KeeperHub org that owns the workflow IDs below.
KEEPERHUB_API_KEY=your-keeperhub-api-key
KEEPERHUB_BASE_URL=https://app.keeperhub.com
# Pre-provisioned AgentNet workflow IDs (defaults are already set in code)
KEEPERHUB_REPUTATION_WORKFLOW_ID=gtpk3bflrnoihktuoa8ci
KEEPERHUB_PAYMENT_WORKFLOW_ID=qpkwci7tw0dr3dlnjv0d6

# Contract Addresses (filled after deployment)
REPUTATION_ORACLE_ADDRESS=0xde94A743D06143b08E4B49E3812D570065BEdC51
WORKER_REGISTRY_ADDRESS=0x31A664dA982495c9496C1626fE25cBFcE7Ab22a5

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
